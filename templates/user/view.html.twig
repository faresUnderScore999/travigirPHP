{% extends 'base.html.twig' %}

{% block title %}User Profile | Admin Travagir{% endblock %}

{% block body %}
<div class="user-profile-container">
    <!-- Breadcrumbs & Header -->
    <div class="profile-header-wrap">
        <nav class="breadcrumb">
            <a href="{{ path('admin_dashboard') }}">Admin</a>
            <span class="separator">/</span>
            <a href="{{ path('admin_users') }}">Users</a>
            <span class="separator">/</span>
            <span class="current">User Details</span>
        </nav>
        
        <div class="header-main">
            <div class="title-section">
                <h1>User Profile</h1>
                <p class="subtitle">Managing account information for {{ user.username }}</p>
            </div>
            <div class="header-actions">
                <a href="{{ path('admin_users') }}" class="btn btn-secondary">
                    <span>⬅️</span> Back to List
                </a>
                <a href="{{ path('admin_users_edit', {'id': user.id}) }}" class="btn btn-primary">
                    <span>✏️</span> Edit User
                </a>
            </div>
        </div>
    </div>

    <!-- Profile Content -->
    <div class="profile-grid">
        <!-- Left Column: Identity Card -->
        <div class="profile-card identity-card">
            <div class="card-content">
                <div class="avatar-section">
                    <div class="avatar-wrapper">
                        {% if user.image_url %}
                            <img src="{{ user.image_url }}" alt="{{ user.username }}" class="profile-avatar">
                        {% else %}
                            <div class="avatar-placeholder">{{ user.username|first|upper }}</div>
                        {% endif %}
                    </div>
                    <div class="identity-info">
                        <h2>{{ user.username }}</h2>
                        <span class="user-badge">{{ user.is_admin ? '🛡️ Administrator' : '👤 Customer' }}</span>
                        <p class="member-since">Member since {{ user.created_at|date('M Y') }}</p>
                    </div>
                </div>
                
                <div class="profile-actions">
                    <form method="post" action="{{ path('admin_users_delete', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                        <button type="submit" class="btn btn-danger btn-full">
                            <span>🗑️</span> Delete Account
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Detailed Information -->
        <div class="profile-details-column">
            <!-- Account Information -->
            <div class="detail-section">
                <div class="section-header">
                    <h3><span>👤</span> Account Details</h3>
                </div>
                <div class="detail-grid">
                    <div class="detail-item">
                        <label>User ID</label>
                        <div class="value">#{{ user.id }}</div>
                    </div>
                    <div class="detail-item">
                        <label>Username</label>
                        <div class="value">{{ user.username }}</div>
                    </div>
                    <div class="detail-item">
                        <label>Email Address</label>
                        <div class="value email-value">{{ user.email }}</div>
                    </div>
                    <div class="detail-item">
                        <label>Registration Date</label>
                        <div class="value">{{ user.created_at|date('F d, Y - H:i') }}</div>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="detail-section">
                <div class="section-header">
                    <h3><span>📞</span> Contact Information</h3>
                </div>
                <div class="detail-grid">
                    <div class="detail-item">
                        <label>Phone Number</label>
                        <div class="value">{{ user.tel ?: 'Not provided' }}</div>
                    </div>
                    <div class="detail-item">
                        <label>Status</label>
                        <div class="value">
                            <span class="status-indicator active"></span>
                            Active Account
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.user-profile-container {
    padding: 30px 0;
    animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Header & Breadcrumbs */
.profile-header-wrap {
    margin-bottom: 30px;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: 0.9rem;
    color: var(--text-muted);
}

.breadcrumb a {
    color: var(--text-muted);
    transition: color 0.2s;
}

.breadcrumb a:hover {
    color: var(--amazon-orange);
}

.breadcrumb .separator {
    color: var(--border-dark);
}

.breadcrumb .current {
    color: var(--text-primary);
    font-weight: 600;
}

.header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
}

.header-main h1 {
    margin: 0;
    font-size: 2.2rem;
    font-weight: 800;
}

.subtitle {
    margin: 4px 0 0 0;
    color: var(--text-muted);
    font-size: 1.1rem;
}

.header-actions {
    display: flex;
    gap: 12px;
}

/* Grid Layout */
.profile-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 30px;
}

/* Identity Card */
.profile-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    overflow: hidden;
    height: fit-content;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.identity-card .card-content {
    padding: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.avatar-section {
    width: 100%;
    margin-bottom: 30px;
}

.avatar-wrapper {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    margin: 0 auto 20px;
    padding: 6px;
    background: linear-gradient(135deg, var(--amazon-orange), var(--amazon-orange-soft));
    box-shadow: 0 8px 25px rgba(255, 153, 0, 0.3);
}

.profile-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--amazon-white);
}

.avatar-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--amazon-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--amazon-orange);
    border: 4px solid var(--amazon-white);
}

.identity-info h2 {
    margin: 0 0 8px 0;
    font-size: 1.6rem;
    color: #ffffff;
}

.user-badge {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
}

.member-since {
    font-size: 0.85rem;
    color: var(--text-muted);
}

.profile-actions {
    width: 100%;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}

.btn-full {
    width: 100%;
    justify-content: center;
}

/* Details Column */
.profile-details-column {
    display: flex;
    flex-direction: column;
    gap: 30px;
}

.detail-section {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.section-header {
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-dark);
}

.section-header h3 {
    margin: 0;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.detail-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}

.detail-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.detail-item label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    font-weight: 700;
}

.detail-item .value {
    font-size: 1.05rem;
    color: var(--text-primary);
    font-weight: 500;
}

.email-value {
    color: var(--amazon-orange-soft) !important;
}

.status-indicator {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 6px;
}

.status-indicator.active {
    background: #16a34a;
    box-shadow: 0 0 10px rgba(22, 163, 74, 0.4);
}

/* Responsive */
@media (max-width: 992px) {
    .profile-grid {
        grid-template-columns: 1fr;
    }
    
    .profile-card {
        max-width: 400px;
        margin: 0 auto;
    }
}

@media (max-width: 600px) {
    .header-main {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .detail-grid {
        grid-template-columns: 1fr;
    }
    
    .header-actions {
        width: 100%;
    }
    
    .header-actions .btn {
        flex: 1;
        text-align: center;
    }
}
</style>
{% endblock %}
