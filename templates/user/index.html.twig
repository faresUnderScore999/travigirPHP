{% extends 'base.html.twig' %}
{% block title %}Manage Users | Travagir{% endblock %}

{% block body %}
<div class="users-page">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <h1>User Management</h1>
            <p class="lead">Manage and organize all registered users.</p>
        </div>
        <a href="{{ path('account_users_new') }}" class="btn btn-register">
            <span>+</span> New User
        </a>
    </div>

    <!-- Alerts -->
    {% for message in app.flashes('success') %}
    <div class="alert alert-success">
        <span class="alert-icon">✓</span>
        {{ message }}
    </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
    <div class="alert alert-error">
        <span class="alert-icon">⚠</span>
        {{ message }}
    </div>
    {% endfor %}

    {% if users is empty %}
    <div class="empty-state">
        <span class="empty-icon">👥</span>
        <h3>No users found</h3>
        <p>There are no registered users yet.</p>
        <a href="{{ path('account_users_new') }}" class="btn btn-primary">Create First User</a>
    </div>
    {% else %}
    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stat-item">
            <span class="stat-value">{{ users|length }}</span>
            <span class="stat-label">Total Users</span>
        </div>
        <div class="stat-item">
            <span class="stat-value">{{ users|filter(u => u.is_admin ?? false)|length }}</span>
            <span class="stat-label">Admins</span>
        </div>
        <div class="stat-item">
            <span class="stat-value">{{ users|filter(u => not (u.is_admin ?? false))|length }}</span>
            <span class="stat-label">Regular Users</span>
        </div>
    </div>

    <!-- Table -->
    <div class="table-container">
        <table class="users-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td class="cell-id">#{{ user.id }}</td>
                    <td class="cell-user">
                        <div class="user-avatar">
                            {{ user.username|first|upper }}
                        </div>
                        <span class="user-name">{{ user.username }}</span>
                    </td>
                    <td class="cell-email">{{ user.email }}</td>
                    <td class="cell-phone">{{ user.tel ?: '-' }}</td>
                    <td class="cell-role">
                        {% if user.is_admin ?? false %}
                        <span class="role-badge admin">Admin</span>
                        {% else %}
                        <span class="role-badge user">User</span>
                        {% endif %}
                    </td>
                    <td class="cell-date">
                        {{ user.created_at ? user.created_at|date('d M Y') : '-' }}
                    </td>
                    <td class="cell-actions">
                        <div class="action-buttons">
                            <a href="{{ path('account_users_view', {'id': user.id}) }}" class="btn-action btn-view" title="View">
                                👁
                            </a>
                            <a href="{{ path('account_users_edit', {'id': user.id}) }}" class="btn-action btn-edit" title="Edit">
                                ✏
                            </a>
                            <form method="post" action="{{ path('account_users_delete', {'id': user.id}) }}" class="action-form">
                                <button type="submit" class="btn-action btn-delete" title="Delete" onclick="return confirm('Are you sure you want to delete this user?');">
                                    🗑
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    <div class="page-footer">
        <a href="{{ path('admin_dashboard') }}" class="back-link">← Back to Admin Dashboard</a>
    </div>
</div>

<style>
.users-page {
    padding: 30px 20px;
}

/* Page Header */
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

/* Stats Bar */
.stats-bar {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 24px;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 12px;
    min-width: 120px;
}

.stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--amazon-orange);
}

.stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
}

.empty-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 16px;
}

.empty-state h3 {
    margin: 0 0 8px 0;
    color: var(--text-primary);
}

.empty-state p {
    color: var(--text-muted);
    margin: 0 0 24px 0;
}

/* Table */
.table-container {
    overflow-x: auto;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
}

.users-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
}

.users-table th {
    text-align: left;
    padding: 16px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-dark);
}

.users-table td {
    padding: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: middle;
}

.users-table tbody tr {
    transition: background 0.2s ease;
}

.users-table tbody tr:hover {
    background: rgba(255, 153, 0, 0.05);
}

.users-table tbody tr:last-child td {
    border-bottom: none;
}

/* Cell Styles */
.cell-id {
    font-weight: 700;
    color: var(--amazon-orange);
    font-family: monospace;
}

.cell-user {
    display: flex;
    align-items: center;
    gap: 12px;
}

.user-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--amazon-orange) 0%, #ff6b35 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: white;
    font-size: 1rem;
}

.user-name {
    font-weight: 600;
    color: var(--text-primary);
}

.cell-email {
    color: var(--text-muted);
}

.cell-phone {
    color: var(--text-muted);
}

.cell-date {
    color: var(--text-muted);
    white-space: nowrap;
}

/* Role Badge */
.role-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
}

.role-badge.admin {
    background: rgba(255, 153, 0, 0.2);
    color: var(--amazon-orange);
}

.role-badge.user {
    background: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 8px;
}

.btn-action {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: all 0.2s ease;
    text-decoration: none;
    background: transparent;
}

.btn-view {
    background: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
}

.btn-view:hover {
    background: #3b82f6;
    color: white;
}

.btn-edit {
    background: rgba(255, 193, 7, 0.2);
    color: #ffc107;
}

.btn-edit:hover {
    background: #ffc107;
    color: white;
}

.btn-delete {
    background: rgba(220, 38, 38, 0.2);
    color: #ef4444;
}

.btn-delete:hover {
    background: #dc2626;
    color: white;
}

/* Page Footer */
.page-footer {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}

.back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
}

.back-link:hover {
    color: var(--amazon-orange);
}

/* Alert */
.alert-success {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(22, 163, 74, 0.1);
    border: 1px solid rgba(22, 163, 74, 0.3);
    border-radius: 12px;
    color: #22c55e;
    font-size: 0.9rem;
    margin-bottom: 20px;
}

.alert-error {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(220, 38, 38, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.3);
    border-radius: 12px;
    color: #ef4444;
    font-size: 0.9rem;
    margin-bottom: 20px;
}

.alert-icon {
    font-size: 1.1rem;
}

/* Responsive */
@media (max-width: 768px) {
    .page-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .stats-bar {
        width: 100%;
    }
    
    .stat-item {
        flex: 1;
        min-width: 80px;
    }
}
</style>
{% endblock %}