{% extends 'base.html.twig' %}

{% block title %}My Reclamations{% endblock %}

{% block body %}
    <h1>My Reclamations</h1>
    <a href="{{ path('user_reclamation_new') }}" class="btn btn-primary mb-3">Create New</a>
    {% if reclamations|length > 0 %}
        <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Reservation ID</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Created At</th>
                    <th>Updated At</th>
                    <th>Admin Response</th>
                    <th>Response Date</th>
                    <th>Resolution Date</th>
                </tr>
            </thead>
            <tbody>
                {% for rec in reclamations %}
                    <tr>
                        <td>{{ rec.id }}</td>
                        <td>{{ rec.reservationId }}</td>
                        <td><a href="{{ path('user_reclamation_detail', {'id': rec.id}) }}">{{ rec.title }}</a></td>
                        <td>{{ rec.description }}</td>
                        <td>{{ rec.status }}</td>
                        <td>{{ rec.priority }}</td>
                        <td>{{ rec.createdAt ? rec.createdAt|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.updatedAt ? rec.updatedAt|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.adminResponse|default('') }}</td>
                        <td>{{ rec.responseDate ? rec.responseDate|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.resolutionDate ? rec.resolutionDate|date('Y-m-d H:i') : '' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    {% else %}
        <p>No reclamations found.</p>
    {% endif %}
{% endblock %}
