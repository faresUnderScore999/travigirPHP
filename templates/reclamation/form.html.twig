{% extends 'base.html.twig' %}

{% block title %}Create Reclamation | Travagir{% endblock %}

{% block body %}
<style>
    /* Professional Support Portal Styling */
    .reclamation-wrapper {
        max-width: 800px;
        margin: 40px auto;
        padding: 0 20px;
        color: var(--text-primary);
    }

    .page-header {
        margin-bottom: 30px;
        border-bottom: 1px solid var(--border-dark);
        padding-bottom: 20px;
    }

    .page-header h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0;
    }

    .page-header p {
        color: var(--text-muted);
        margin-top: 8px;
        font-size: 0.95rem;
    }

    /* Form Card */
    .form-card {
        background: var(--amazon-white);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* Context Info (Current Reservation) */
    .context-bar {
        background: rgba(255, 153, 0, 0.05);
        border: 1px solid rgba(255, 153, 0, 0.2);
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .context-label {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--amazon-orange);
        letter-spacing: 0.5px;
    }

    .context-value {
        font-weight: 600;
        font-size: 0.95rem;
    }

    /* Professional Inputs */
    .form-group {
        margin-bottom: 25px;
    }

    .form-group label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .modern-control {
        width: 100%;
        background: var(--amazon-dark);
        border: 1px solid var(--border-dark);
        color: white;
        padding: 14px 16px;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: inherit;
    }

    .modern-control:focus {
        outline: none;
        border-color: var(--amazon-orange);
        box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.15);
    }

    textarea.modern-control {
        min-height: 150px;
        resize: vertical;
    }

    /* Action Footer */
    .form-footer {
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid var(--border-dark);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .submit-btn {
        padding: 14px 35px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
    }

    .cancel-link {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .cancel-link:hover {
        color: #ff4d4d;
    }

    /* Error Alert Styling */
    .error-box {
        background: rgba(255, 77, 77, 0.1);
        border: 1px solid #ff4d4d;
        color: #ff4d4d;
        padding: 15px 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        font-size: 0.9rem;
    }
</style>

<div class="reclamation-wrapper">
    <header class="page-header">
        <h1>Submit a Reclamation</h1>
        <p>Please provide details regarding your experience. Our team will review your claim shortly.</p>
    </header>

    {% if errors %}
        <div class="error-box">
            <strong style="display: block; margin-bottom: 5px;">There were issues with your submission:</strong>
            <ul style="margin: 0; padding-left: 20px;">
                {% for field, msgs in errors %}
                    <li>{{ field|capitalize }}: {{ msgs|join(', ') }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="form-card">
        <form method="post" action="{{ path('user_reclamation_new') }}">
            
            {% if data.reservation_id is defined %}
                <div class="context-bar">
                    <span class="context-label">Linked To</span>
                    <span class="context-value">Booking #{{ data.reservation_id }}</span>
                    <input type="hidden" name="reservation_id" value="{{ data.reservation_id }}">
                </div>
            {% else %}
                <div class="form-group">
                    <label for="reservation_id">Reservation Reference ID</label>
                    <input type="number" name="reservation_id" id="reservation_id" 
                           class="modern-control" placeholder="e.g. 1024" 
                           value="{{ data.reservation_id|default('') }}" required>
                </div>
            {% endif %}

            <div class="form-group">
                <label for="title">Subject Title</label>
                <input type="text" name="title" id="title" 
                       class="modern-control" placeholder="Briefly summarize the issue" 
                       value="{{ data.title|default('') }}" required>
            </div>

            <div class="form-group">
                <label for="description">Detailed Description</label>
                <textarea name="description" id="description" 
                          class="modern-control" 
                          placeholder="Please provide as much detail as possible so we can assist you better..." 
                          required>{{ data.description|default('') }}</textarea>
            </div>

            <div class="form-footer">
                <a href="{{ path('account_bookings') }}" class="cancel-link">Discard and return</a>
                <button type="submit" class="btn btn-register submit-btn">Submit Claim</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}