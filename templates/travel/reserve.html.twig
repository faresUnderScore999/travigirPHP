{% extends 'base.html.twig' %}

{% block title %}Reserve Voyage | Travagir{% endblock %}

{% block body %}
<style>
    .checkout-wrapper {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 20px;
        color: var(--text-primary);
    }

    .checkout-header {
        margin-bottom: 30px;
    }

    .checkout-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    /* Grid Layout */
    .checkout-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 30px;
        align-items: start;
    }

    /* Panels */
    .checkout-panel {
        background: var(--amazon-white);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 20px;
    }

    .panel-section-title {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--amazon-orange-soft);
        letter-spacing: 1px;
        margin-bottom: 20px;
        display: block;
        border-bottom: 1px solid var(--border-dark);
        padding-bottom: 10px;
    }

    /* Trip Details Styling */
    .trip-info-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .trip-info-item:last-child { border: none; }

    .trip-label { color: var(--text-muted); font-size: 0.95rem; }
    .trip-value { font-weight: 600; text-align: right; }

    /* Form Styling */
    .form-group label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .modern-input {
        width: 100%;
        background: var(--amazon-dark);
        border: 1px solid var(--border-dark);
        color: white;
        padding: 15px;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.2s;
    }

    .modern-input:focus {
        outline: none;
        border-color: var(--amazon-orange);
        box-shadow: 0 0 0 2px rgba(255, 153, 0, 0.2);
    }

    /* Summary Sidebar */
    .summary-sidebar {
        position: sticky;
        top: 100px;
    }

    .price-breakdown {
        margin-top: 20px;
    }

    .total-row {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--border-dark);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .total-price {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--amazon-orange);
    }

    .offer-tag {
        display: inline-block;
        background: rgba(255, 153, 0, 0.1);
        color: var(--amazon-orange);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 5px;
    }

    /* Button */
    .btn-checkout {
        width: 100%;
        padding: 18px;
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 20px;
        cursor: pointer;
    }

    @media (max-width: 850px) {
        .checkout-grid { grid-template-columns: 1fr; }
        .summary-sidebar { position: static; }
    }
</style>

<div class="checkout-wrapper">
    <header class="checkout-header">
        <h1>Secure Reservation</h1>
        <p class="lead">Confirm your details to initiate your booking request.</p>
    </header>

    {% if error is defined and error %}
        <div class="alert alert-error">{{ error }}</div>
    {% endif %}

    {% if success is defined and success %}
        <div class="alert alert-success">{{ success }}</div>
    {% endif %}

    <form method="post" class="checkout-grid">
        <div class="main-content">
            <div class="checkout-panel">
                <span class="panel-section-title">Trip Destination</span>
                <div class="trip-info-item">
                    <span class="trip-label">Experience</span>
                    <span class="trip-value">{{ voyage.title }}</span>
                </div>
                <div class="trip-info-item">
                    <span class="trip-label">Location</span>
                    <span class="trip-value">{{ voyage.destination }}</span>
                </div>
                <div class="trip-info-item">
                    <span class="trip-label">Itinerary Dates</span>
                    <span class="trip-value">
                        {{ voyage.start_date ? voyage.start_date|date('d M Y') : 'TBD' }} 
                        — 
                        {{ voyage.end_date ? voyage.end_date|date('d M Y') : 'TBD' }}
                    </span>
                </div>
            </div>

            <div class="checkout-panel">
                <span class="panel-section-title">Traveler Information</span>
                <div class="form-group">
                    <label for="number_of_people">How many people are traveling?</label>
                    <input type="number" id="number_of_people" name="number_of_people" 
                           class="modern-input" value="1" min="1" required>
                    <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 10px;">
                        Note: Final price will be calculated based on this number.
                    </p>
                </div>
            </div>
        </div>

        <div class="summary-sidebar">
            <div class="checkout-panel">
                <span class="panel-section-title">Payment Summary</span>
                
                <div class="price-breakdown">
                    <div class="trip-info-item">
                        <span class="trip-label">Base Rate (per person)</span>
                        <span class="trip-value">${{ voyage.price|number_format(2) }}</span>
                    </div>

                    {% if offer %}
                        <div class="trip-info-item">
                            <span class="trip-label">Special Offer</span>
                            <div style="text-align: right;">
                                <span class="trip-value" style="color: var(--amazon-orange);">
                                    -{{ offer.discount_percentage }}%
                                </span><br>
                                <span class="offer-tag">{{ offer.title }}</span>
                            </div>
                        </div>
                    {% endif %}

                    <div class="total-row">
                        <span style="font-weight: 700;">Estimate Total</span>
                        <span class="total-price" id="display-total">
                            {% set price = voyage.price %}
                            {% if offer %}
                                {% set price = price * (1 - (offer.discount_percentage / 100)) %}
                            {% endif %}
                            ${{ price|number_format(2) }}
                        </span>
                    </div>
                </div>

                <button type="submit" class="btn btn-register btn-checkout">
                    Complete Reservation
                </button>
                
                <p style="text-align: center; font-size: 0.75rem; color: var(--text-muted); margin-top: 15px;">
                    <svg width="12" height="12" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 5px;">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                    Your request requires admin approval.
                </p>
            </div>
        </div>
    </form>
</div>

<script>
    // Optional: Real-time price update for the UI
    const input = document.getElementById('number_of_people');
    const display = document.getElementById('display-total');
    const basePrice = {{ voyage.price }};
    const discount = {{ offer ? (1 - (offer.discount_percentage / 100)) : 1 }};

    input.addEventListener('input', () => {
        const total = (basePrice * discount * input.value).toLocaleString('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
        display.innerText = `$${total}`;
    });
</script>
{% endblock %}