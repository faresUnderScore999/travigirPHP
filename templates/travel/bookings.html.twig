{% extends 'base.html.twig' %}

{% block title %}My Bookings | Travagir{% endblock %}

{% block body %}
<style>
    /* Professional Bookings List Styling */
    .bookings-container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 20px;
        color: var(--text-primary);
    }

    .page-header {
        margin-bottom: 40px;
        border-bottom: 1px solid var(--border-dark);
        padding-bottom: 20px;
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .page-header .lead {
        color: var(--text-muted);
        font-size: 1rem;
    }

    /* The Booking Card */
    .booking-card {
        background: var(--amazon-white); /* #1b2635 */
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .booking-card:hover {
        border-color: var(--amazon-orange-soft);
        transform: translateY(-2px);
    }

    /* Card Header Bar */
    .card-top-bar {
        background: rgba(255, 255, 255, 0.03);
        padding: 15px 25px;
        border-bottom: 1px solid var(--border-dark);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .booking-meta-item {
        display: flex;
        flex-direction: column;
    }

    .meta-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 1px;
        font-weight: 700;
    }

    .meta-value {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    /* Main Content Area */
    .card-main-content {
        padding: 25px;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr auto;
        align-items: center;
        gap: 20px;
    }

    .voyage-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--amazon-orange-soft);
        text-decoration: none;
    }

    .price-tag {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text-primary);
    }

    /* Professional Status Pill */
    .status-pill {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        border: 1px solid var(--amazon-orange);
        color: var(--amazon-orange);
        background: rgba(255, 153, 0, 0.05);
    }

    .status-cancelled {
        border-color: #ff4d4d;
        color: #ff4d4d;
        background: rgba(255, 77, 77, 0.05);
    }

    /* Buttons */
    .btn-group {
        display: flex;
        gap: 10px;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: var(--amazon-white);
        border: 2px dashed var(--border-dark);
        border-radius: 12px;
    }

    .empty-state p {
        color: var(--text-muted);
        margin-bottom: 25px;
    }

    @media (max-width: 850px) {
        .card-main-content {
            grid-template-columns: 1fr 1fr;
        }
        .card-top-bar {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<section class="bookings-container">
    <div class="page-header">
        <h1>My Bookings</h1>
        <p class="lead">Review and manage your current trip reservations.</p>
    </div>

    {% if bookings is empty %}
        <div class="empty-state">
            <p>No bookings yet. Explore voyages and book your next adventure.</p>
            <a href="{{ path('travel_voyages') }}" class="btn btn-register">Browse Voyages</a>
        </div>
    {% else %}
        <div class="bookings-list">
            {% for reservation in bookings %}
                <article class="booking-card">
                    <div class="card-top-bar">
                        <div class="booking-meta-item">
                            <span class="meta-label">Booking Placed</span>
                            <span class="meta-value">{{ reservation.reservation_date|date('d M Y') }}</span>
                        </div>
                        <div class="booking-meta-item">
                            <span class="meta-label">Reference</span>
                            <span class="meta-value">#{{ reservation.id }}</span>
                        </div>
                        <div class="status-pill status-{{ reservation.status|lower }}">
                            {{ reservation.status }}
                        </div>
                    </div>

                    <div class="card-main-content">
                        <div>
                            <span class="meta-label">Experience</span>
                            <div style="margin-top: 5px;">
                                <a href="{{ path('account_reservation_detail', {id: reservation.id}) }}" class="voyage-title">
                                    {{ reservation.voyage_title|default('Trip to ' ~ reservation.destination) }}
                                </a>
                            </div>
                        </div>

                        <div>
                            <span class="meta-label">Travelers</span>
                            <div class="meta-value" style="margin-top: 5px;">
                                {{ reservation.number_of_people }} Person(s)
                            </div>
                        </div>

                        <div>
                            <span class="meta-label">Total Paid</span>
                            <div class="price-tag" style="margin-top: 5px;">
                                ${{ reservation.total_price|number_format(2, '.', ',') }}
                            </div>
                        </div>

                        <div class="btn-group">
                            <a href="{{ path('account_reservation_detail', {id: reservation.id}) }}" class="btn btn-login" style="padding: 8px 20px;">
                                View Details
                            </a>
                                {% if is_admin_view %}
                            {% if reservation.status == 'PENDING' or reservation.status == 'CONFIRMED' %}
                                <form method="post" action="{{ path('account_reservation_detail', {id: reservation.id}) }}" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                    <button type="submit" name="action_cancel" class="btn btn-danger" style="padding: 8px 20px;">
                                        Cancel
                                    </button>
                                </form>
                            {% endif %}
                                {% endif %}
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>
{% endblock %}