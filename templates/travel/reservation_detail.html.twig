{% extends 'base.html.twig' %}

{% block title %}Reservation Detail | Travagir{% endblock %}

{% block body %}
<style>
    /* Professional Dashboard Overrides */
    .reservation-wrapper {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 20px;
        color: var(--text-primary);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Top Summary Bar */
    .booking-summary-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 20px 30px;
        background: var(--amazon-white);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
    }

    .booking-id-group h1 {
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .booking-id-group p {
        margin: 5px 0 0;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    /* Refined Status Pill */
    .status-pill {
        padding: 6px 16px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: rgba(255, 153, 0, 0.1);
        border: 1px solid var(--amazon-orange);
        color: var(--amazon-orange);
    }

    .status-cancelled {
        background: rgba(255, 77, 77, 0.1);
        border-color: #ff4d4d;
        color: #ff4d4d;
    }

    /* Two-Column Detail Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
    }

    .detail-panel {
        background: var(--amazon-white);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 30px;
    }

    .panel-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--amazon-orange-soft);
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid var(--border-dark);
        padding-bottom: 15px;
    }

    /* Info Rows */
    .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .info-row:last-child { margin-bottom: 0; }

    .info-label {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .info-value {
        font-weight: 600;
        text-align: right;
        color: var(--text-primary);
    }

    /* Price Section Special Styling */
    .price-panel {
        background: var(--amazon-navy);
        border-color: var(--amazon-slate);
    }

    .total-amount {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--amazon-orange);
        display: block;
        margin-top: 10px;
    }

    /* Action Footer */
    .action-panel {
        grid-column: 1 / -1;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 15px;
        margin-top: 10px;
    }

    .refund-container {
        grid-column: 1 / -1;
        margin-top: 20px;
        background: rgba(0,0,0,0.2);
        border-radius: 8px;
        padding: 25px;
        border: 1px dashed var(--border-dark);
    }

    .refund-container textarea {
        width: 100%;
        background: var(--amazon-dark);
        border: 1px solid var(--border-dark);
        color: white;
        padding: 15px;
        border-radius: 6px;
        margin: 15px 0;
        resize: vertical;
    }

    .back-btn {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .back-btn:hover { color: var(--amazon-orange); }

    @media (max-width: 850px) {
        .detail-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="reservation-wrapper">
    {% if error %} <div class="alert alert-error">{{ error }}</div> {% endif %}
    {% if success %} <div class="alert alert-success">{{ success }}</div> {% endif %}

    <div class="booking-summary-bar">
        <div class="booking-id-group">
            <p>RESERVATION</p>
            <h1>#{{ reservation.id }}</h1>
        </div>
        <div class="booking-id-group" style="text-align: center;">
            <p>BOOKING DATE</p>
            <span style="font-weight: 600;">{{ reservation.reservation_date|date('d M Y') }}</span>
        </div>
        <div class="status-pill status-{{ reservation.status|lower }}">
            {{ reservation.status }}
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-panel">
            <div class="panel-title">Trip Overview</div>
            
            <div class="info-row">
                <span class="info-label">Voyage</span>
                <span class="info-value">{{ reservation.voyage_title }}</span>
            </div>
            
            <div class="info-row">
                <span class="info-label">Destination</span>
                <span class="info-value">{{ reservation.destination }}</span>
            </div>

            <div class="info-row">
                <span class="info-label">Travel Period</span>
                <span class="info-value">
                    {{ reservation.voyage_start ? reservation.voyage_start|date('d M Y') : 'TBD' }} 
                    — 
                    {{ reservation.voyage_end ? reservation.voyage_end|date('d M Y') : 'TBD' }}
                </span>
            </div>

            <div class="info-row">
                <span class="info-label">Group Size</span>
                <span class="info-value">{{ reservation.number_of_people }} Person(s)</span>
            </div>

            {% if is_admin_view %}
                <div class="panel-title" style="margin-top: 40px;">Customer Information</div>
                <div class="info-row">
                    <span class="info-label">Primary Contact</span>
                    <span class="info-value">{{ reservation.user_name }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email Address</span>
                    <span class="info-value">{{ reservation.user_email }}</span>
                </div>
            {% endif %}
        </div>

        <div class="detail-panel price-panel">
            <div class="panel-title" style="color: var(--text-primary);">Financial Summary</div>
            
            <div class="info-row">
                <span class="info-label">Base Rate</span>
                <span class="info-value">${{ (reservation.total_price / (reservation.number_of_people ?: 1))|number_format(2) }}</span>
            </div>
            
            <div class="info-row">
                <span class="info-label">Quantity</span>
                <span class="info-value">x {{ reservation.number_of_people }}</span>
            </div>

            <div style="margin-top: 30px; border-top: 1px solid var(--border-dark); padding-top: 20px;">
                <span class="info-label" style="color: var(--text-primary);">Total Paid</span>
                <span class="total-amount">${{ reservation.total_price|number_format(2) }}</span>
            </div>
        </div>

        <div class="action-panel">
            <a href="{{ is_admin_view ? path('admin_reservations') : path('account_bookings') }}" class="back-btn">
                ← Return to List
            </a>

            {% if is_admin_view %}
                {% if reservation.status == 'PENDING' %}
                    <form method="post">
                        <button type="submit" name="action_confirm" class="btn btn-register">Confirm Booking</button>
                    </form>
                {% endif %}

                {% if reservation.status not in ['CANCELLED', 'COMPLETED'] %}
                    <form method="post">
                        <button type="submit" name="action_cancel" class="btn btn-danger">Cancel Booking</button>
                    </form>
                {% endif %}
            {% endif %}

            <a href="{{ path('user_reclamation_new') }}?reservation_id={{ reservation.id }}" class="btn btn-primary">File Reclamation</a>
        </div>

        {% if is_admin_view and reservation.status in ['CONFIRMED', 'CANCELLED', 'COMPLETED'] %}
            <div class="refund-container">
                <div class="panel-title" style="border: none; margin-bottom: 0;">Initiate Refund</div>
                <form method="post">
                    <textarea id="refund_reason" name="refund_reason" rows="3" placeholder="Provide a detailed reason for the refund..." required></textarea>
                    <button type="submit" name="action_refund" class="btn btn-login">Process Refund Request</button>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}