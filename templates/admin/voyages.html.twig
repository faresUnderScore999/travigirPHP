{% extends 'base.html.twig' %}

{% block title %}Manage Voyages | Admin{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>Manage Voyages</h1>
            <p class="lead">Create, edit, and delete travel packages</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_voyage_new') }}" class="btn btn-primary">
                <span>➕</span> Add New Voyage
            </a>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">
                ← Back to Dashboard
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Destination</th>
                    <th>Price</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Activities</th>
                    <th>Offers</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for voyage in voyages %}
                <tr>
                    <td>{{ voyage.id }}</td>
                    <td>
                        <strong>{{ voyage.title }}</strong>
                        {% if voyage.image_url and voyage.image_url[0] %}
                            <img src="{{ voyage.image_url[0] }}" alt="{{ voyage.title }}" class="table-thumb">
                        {% endif %}
                    </td>
                    <td>{{ voyage.destination }}</td>
                    <td>${{ voyage.price|number_format(2) }}</td>
                    <td>{{ voyage.start_date }}</td>
                    <td>{{ voyage.end_date }}</td>
                    <td><span class="badge">{{ voyage.activities_count }}</span></td>
                    <td><span class="badge">{{ voyage.offers_count }}</span></td>
                    <td class="actions-cell">
                        <a href="{{ path('admin_voyage_manage', {id: voyage.id}) }}" class="btn btn-sm btn-manage">Manage</a>
                        <a href="{{ path('admin_voyage_edit', {id: voyage.id}) }}" class="btn btn-sm btn-edit">Edit</a>
                        <a href="{{ path('admin_voyage_delete', {id: voyage.id}) }}" class="btn btn-sm btn-delete" onclick="return confirm('Are you sure you want to delete this voyage?');">Delete</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="empty-state">No voyages found. Create your first voyage!</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-primary:hover {
    background: #e68a00;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
}

.btn-sm {
    padding: 6px 12px;
    font-size: 0.85rem;
}

.btn-edit {
    background: #3b82f6;
    color: white;
}

.btn-delete {
    background: #ef4444;
    color: white;
}

.alert {
    padding: 14px 20px;
    border-radius: 8px;
    margin-bottom: 24px;
}

.alert-success {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid #22c55e;
    color: #22c55e;
}

.alert-error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid #ef4444;
    color: #ef4444;
}

.admin-table-container {
    background: var(--amazon-white);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-dark);
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
}

.admin-table th,
.admin-table td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border-dark);
}

.admin-table th {
    background: rgba(15, 23, 34, 0.5);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.admin-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.03);
}

.admin-table tbody tr:last-child td {
    border-bottom: none;
}

.table-thumb {
    width: 60px;
    height: 40px;
    object-fit: cover;
    border-radius: 4px;
    margin-top: 6px;
    display: block;
}

.badge {
    background: rgba(255, 153, 0, 0.2);
    color: var(--amazon-orange);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
}

.actions-cell {
    display: flex;
    gap: 8px;
}

.delete-form {
    display: inline;
}

.empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 40px !important;
}

@media (max-width: 1024px) {
    .admin-table {
        display: block;
        overflow-x: auto;
    }
}
</style>
{% endblock %}