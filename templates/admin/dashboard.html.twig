{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard | Travagir{% endblock %}

{% block body %}
<div class="admin-panel-container">
    <!-- Breadcrumbs & Header -->
    <div class="dashboard-header-wrap">
        <nav class="breadcrumb">
            <span class="current">Admin Dashboard</span>
        </nav>
        
        <div class="header-main">
            <div class="title-section">
                <h1>Control Center</h1>
                <p class="subtitle">Welcome back! Here's an overview of your travel agency performance.</p>
            </div>
            <div class="header-actions">
                <a href="{{ path('admin_users_new') }}" class="btn btn-primary">
                    <span>➕</span> Add New User
                </a>
                <a href="{{ path('admin_ai_assistant') }}" class="btn btn-secondary">
                    <span>🤖</span> AI Assistant
                </a>
            </div>
        </div>
    </div>

    <!-- Top Level Statistics -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon users-icon">👥</div>
                <div class="stat-trend positive">Total Growth</div>
            </div>
            <div class="stat-body">
                <span class="stat-value">{{ stats.total_users }}</span>
                <span class="stat-label">Registered Users</span>
            </div>
            <a href="{{ path('admin_users') }}" class="stat-footer">View User Directory →</a>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon reservations-icon">📋</div>
                <div class="stat-trend">Bookings</div>
            </div>
            <div class="stat-body">
                <span class="stat-value">{{ stats.total_reservations }}</span>
                <span class="stat-label">Total Reservations</span>
            </div>
            <a href="{{ path('admin_reservations') }}" class="stat-footer">Manage Bookings →</a>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon revenue-icon">💰</div>
                <div class="stat-trend positive">Revenue</div>
            </div>
            <div class="stat-body">
                <span class="stat-value">${{ stats.total_revenue|number_format(0) }}</span>
                <span class="stat-label">Total Earnings</span>
            </div>
            <div class="stat-footer">Confirmed Payments Only</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon voyages-icon">✈️</div>
                <div class="stat-trend">Inventory</div>
            </div>
            <div class="stat-body">
                <span class="stat-value">{{ stats.total_voyages }}</span>
                <span class="stat-label">Active Voyages</span>
            </div>
            <a href="{{ path('admin_voyages') }}" class="stat-footer">Edit Packages →</a>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="dashboard-main-grid">
        <!-- Left Side: Activity & Tools -->
        <div class="dashboard-left-col">
            <!-- Quick Management Tools -->
            <section class="tools-section">
                <div class="section-header">
                    <h2><span>🛠️</span> Management Tools</h2>
                </div>
                <div class="tools-grid">
                    <a href="{{ path('admin_users') }}" class="tool-item">
                        <span class="tool-icon">👤</span>
                        <div class="tool-text">
                            <span class="tool-name">Users</span>
                            <span class="tool-desc">Accounts & Permissions</span>
                        </div>
                    </a>
                    <a href="{{ path('admin_reservations') }}" class="tool-item">
                        <span class="tool-icon">📝</span>
                        <div class="tool-text">
                            <span class="tool-name">Bookings</span>
                            <span class="tool-desc">Manage Reservations</span>
                        </div>
                    </a>
                    <a href="{{ path('admin_voyages') }}" class="tool-item">
                        <span class="tool-icon">✈️</span>
                        <div class="tool-text">
                            <span class="tool-name">Voyages</span>
                            <span class="tool-desc">Travel Packages</span>
                        </div>
                    </a>
                    <a href="{{ path('admin_offers') }}" class="tool-item">
                        <span class="tool-icon">🏷️</span>
                        <div class="tool-text">
                            <span class="tool-name">Offers</span>
                            <span class="tool-desc">Deals & Promotions</span>
                        </div>
                    </a>
                    <a href="{{ path('admin_activities') }}" class="tool-item">
                        <span class="tool-icon">🎯</span>
                        <div class="tool-text">
                            <span class="tool-name">Activities</span>
                            <span class="tool-desc">Experience Options</span>
                        </div>
                    </a>
                    <a href="{{ path('admin_reclamations') }}" class="tool-item">
                        <span class="tool-icon">⚠️</span>
                        <div class="tool-text">
                            <span class="tool-name">Complaints</span>
                            <span class="tool-desc">User Support</span>
                        </div>
                    </a>
                </div>
            </section>

            <!-- Recent Activity Tables -->
            <div class="recent-activity-grid">
                <!-- Recent Bookings -->
                <section class="activity-card">
                    <div class="card-header">
                        <h3>Recent Bookings</h3>
                        <a href="{{ path('admin_reservations') }}" class="view-link">See all</a>
                    </div>
                    {% if recent_reservations|length > 0 %}
                        <div class="activity-list">
                            {% for reservation in recent_reservations %}
                                <div class="activity-item">
                                    <div class="item-main">
                                        <div class="item-icon">📅</div>
                                        <div class="item-info">
                                            <span class="item-title">{{ reservation.user_name }}</span>
                                            <span class="item-subtitle">Voyage #{{ reservation.voyage_id }}</span>
                                        </div>
                                    </div>
                                    <div class="item-meta">
                                        <span class="item-amount">${{ reservation.total_price|number_format(0) }}</span>
                                        <span class="status-pill status-{{ reservation.status|lower }}">{{ reservation.status }}</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="empty-text">No recent bookings found.</p>
                    {% endif %}
                </section>

                <!-- New Registered Users -->
                <section class="activity-card">
                    <div class="card-header">
                        <h3>Newest Users</h3>
                        <a href="{{ path('admin_users') }}" class="view-link">See all</a>
                    </div>
                    {% if recent_users|length > 0 %}
                        <div class="activity-list">
                            {% for user in recent_users %}
                                <div class="activity-item">
                                    <div class="item-main">
                                        <div class="user-avatar-mini">
                                            {% if user.image_url %}
                                                <img src="{{ user.image_url }}" alt="">
                                            {% else %}
                                                {{ user.username|first|upper }}
                                            {% endif %}
                                        </div>
                                        <div class="item-info">
                                            <span class="item-title">{{ user.username }}</span>
                                            <span class="item-subtitle">{{ user.email }}</span>
                                        </div>
                                    </div>
                                    <div class="item-meta">
                                        <span class="item-date">{{ user.created_at|date('M d') }}</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="empty-text">No new users registered.</p>
                    {% endif %}
                </section>
            </div>
        </div>

        <!-- Right Side: Metrics & Insights -->
        <div class="dashboard-right-col">
            <!-- Reservation Status Mix -->
            <section class="insights-card">
                <div class="card-header">
                    <h3>Booking Status Mix</h3>
                </div>
                <div class="status-distribution">
                    <div class="dist-item">
                        <div class="dist-header">
                            <span class="dist-label">Confirmed</span>
                            <span class="dist-count">{{ stats.confirmed_reservations }}</span>
                        </div>
                        <div class="dist-bar">
                            <div class="dist-fill confirmed" style="width: {{ stats.total_reservations > 0 ? (stats.confirmed_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="dist-item">
                        <div class="dist-header">
                            <span class="dist-label">Pending</span>
                            <span class="dist-count">{{ stats.pending_reservations }}</span>
                        </div>
                        <div class="dist-bar">
                            <div class="dist-fill pending" style="width: {{ stats.total_reservations > 0 ? (stats.pending_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="dist-item">
                        <div class="dist-header">
                            <span class="dist-label">Cancelled</span>
                            <span class="dist-count">{{ stats.cancelled_reservations }}</span>
                        </div>
                        <div class="dist-bar">
                            <div class="dist-fill cancelled" style="width: {{ stats.total_reservations > 0 ? (stats.cancelled_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- System Logs Quick Access -->
            <section class="insights-card">
                <div class="card-header">
                    <h3>Analytics & Logs</h3>
                </div>
                <div class="logs-grid">
                    <a href="{{ path('admin_login_stats') }}" class="log-item">
                        <span class="log-icon">🔐</span>
                        <span class="log-name">Login Logs</span>
                    </a>
                    <a href="{{ path('admin_search_history') }}" class="log-item">
                        <span class="log-icon">🔎</span>
                        <span class="log-name">Search Logs</span>
                    </a>
                    <a href="{{ path('admin_voyage_visits') }}" class="log-item">
                        <span class="log-icon">📊</span>
                        <span class="log-name">Visit Stats</span>
                    </a>
                    <a href="{{ path('admin_refunds') }}" class="log-item">
                        <span class="log-icon">💸</span>
                        <span class="log-name">Refunds</span>
                    </a>
                </div>
            </section>
        </div>
    </div>
</div>

<style>
.admin-panel-container {
    padding: 30px 0;
    animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Header */
.dashboard-header-wrap {
    margin-bottom: 30px;
}

.breadcrumb {
    margin-bottom: 16px;
    font-size: 0.9rem;
    color: var(--text-muted);
}

.breadcrumb .current {
    color: var(--amazon-orange);
    font-weight: 700;
}

.header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
}

.header-main h1 {
    margin: 0;
    font-size: 2.2rem;
    font-weight: 800;
}

.subtitle {
    margin: 4px 0 0 0;
    color: var(--text-muted);
    font-size: 1.1rem;
}

.header-actions {
    display: flex;
    gap: 12px;
}

/* Stats Cards */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.stat-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    position: relative;
    overflow: hidden;
}

.stat-card:hover {
    transform: translateY(-5px);
    border-color: var(--amazon-orange);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

.stat-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
}

.users-icon { color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
.reservations-icon { color: #10b981; background: rgba(16, 185, 129, 0.1); }
.revenue-icon { color: #f59e0b; background: rgba(245, 158, 11, 0.1); }
.voyages-icon { color: #8b5cf6; background: rgba(139, 92, 246, 0.1); }

.stat-trend {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 4px 10px;
    border-radius: 20px;
}

.stat-trend.positive {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
}

.stat-value {
    display: block;
    font-size: 2.2rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 4px;
}

.stat-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
}

.stat-footer {
    margin-top: 20px;
    padding-top: 15px;
    border-top: 1px solid var(--border-dark);
    display: block;
    color: var(--amazon-orange-soft);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
}

.stat-footer:hover {
    text-decoration: underline;
}

/* Main Grid */
.dashboard-main-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 30px;
}

/* Tool Section */
.tools-section {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 30px;
}

.section-header {
    margin-bottom: 24px;
}

.section-header h2 {
    margin: 0;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 15px;
}

.tool-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background: var(--amazon-dark);
    border: 1px solid var(--border-dark);
    border-radius: 12px;
    transition: all 0.2s;
    text-decoration: none;
}

.tool-item:hover {
    border-color: var(--amazon-orange);
    transform: translateX(5px);
    background: rgba(255, 153, 0, 0.05);
}

.tool-icon {
    font-size: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amazon-white);
    border-radius: 10px;
}

.tool-text {
    display: flex;
    flex-direction: column;
}

.tool-name {
    font-weight: 700;
    color: #ffffff;
}

.tool-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
}

/* Activity Cards */
.recent-activity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 20px;
}

.activity-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.card-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
}

.view-link {
    font-size: 0.85rem;
    color: var(--amazon-orange);
    font-weight: 600;
    text-decoration: none;
}

.view-link:hover {
    text-decoration: underline;
}

.activity-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.activity-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    background: var(--amazon-dark);
    border-radius: 12px;
    border: 1px solid transparent;
    transition: border-color 0.2s;
}

.activity-item:hover {
    border-color: var(--border-dark);
}

.item-main {
    display: flex;
    align-items: center;
    gap: 12px;
}

.item-icon {
    width: 36px;
    height: 36px;
    background: var(--amazon-white);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.user-avatar-mini {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--amazon-orange);
    color: #0a0f1c;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.user-avatar-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.item-info {
    display: flex;
    flex-direction: column;
}

.item-title {
    font-weight: 600;
    color: #ffffff;
}

.item-subtitle {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.item-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
}

.item-amount {
    font-weight: 700;
    color: var(--amazon-orange);
}

.item-date {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.status-pill {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
}

.status-confirmed { background: rgba(16, 185, 129, 0.1); color: #10b981; }
.status-pending { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
.status-cancelled { background: rgba(239, 68, 68, 0.1); color: #ef4444; }

/* Right Column Cards */
.insights-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 24px;
}

.status-distribution {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.dist-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.dist-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    font-weight: 600;
}

.dist-bar {
    height: 6px;
    background: var(--amazon-dark);
    border-radius: 10px;
    overflow: hidden;
}

.dist-fill {
    height: 100%;
    border-radius: 10px;
}

.dist-fill.confirmed { background: #10b981; }
.dist-fill.pending { background: #f59e0b; }
.dist-fill.cancelled { background: #ef4444; }

.logs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.log-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 15px;
    background: var(--amazon-dark);
    border: 1px solid var(--border-dark);
    border-radius: 12px;
    transition: all 0.2s;
    text-align: center;
    text-decoration: none;
}

.log-item:hover {
    border-color: var(--amazon-orange);
    background: rgba(255, 153, 0, 0.05);
}

.log-icon { font-size: 1.4rem; }
.log-name { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); }

/* Empty Text */
.empty-text {
    text-align: center;
    color: var(--text-muted);
    padding: 20px;
    font-style: italic;
}

/* Responsive */
@media (max-width: 1100px) {
    .dashboard-main-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .recent-activity-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 600px) {
    .header-main {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .header-actions {
        width: 100%;
    }
    
    .header-actions .btn {
        flex: 1;
        justify-content: center;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}