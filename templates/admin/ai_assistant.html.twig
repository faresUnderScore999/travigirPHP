{% extends 'base.html.twig' %}

{% block title %}AI Analytics Assistant | Admin Travagir{% endblock %}

{% block body %}
<div class="ai-assistant-container">
    <!-- Breadcrumbs & Header -->
    <div class="ai-header-wrap">
        <nav class="breadcrumb">
            <a href="{{ path('admin_dashboard') }}">Admin</a>
            <span class="separator">/</span>
            <span class="current">AI Analytics Assistant</span>
        </nav>
        
        <div class="header-main">
            <div class="title-section">
                <h1>AI Insights Console</h1>
                <p class="subtitle">Interact with our intelligence engine to extract travel data trends and metrics.</p>
            </div>
            <div class="header-actions">
                <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">
                    <span>⬅️</span> Dashboard
                </a>
                <button class="btn btn-primary" onclick="window.location.reload()">
                    <span>🔄</span> Reset Session
                </button>
            </div>
        </div>
    </div>

    <!-- Main Console Grid -->
    <div class="ai-console-grid">
        <!-- Sidebar: Info & Quick Actions -->
        <div class="console-sidebar">
            <div class="sidebar-section">
                <h3><span>🧠</span> Capabilities</h3>
                <ul class="capability-list">
                    <li>Analyze conversion rates</li>
                    <li>Track popular destinations</li>
                    <li>Summarize weekly metrics</li>
                    <li>Monitor user growth</li>
                    <li>Report booking trends</li>
                </ul>
            </div>

            <div class="sidebar-section">
                <h3><span>💡</span> Quick Queries</h3>
                <div class="suggestion-grid">
                    <button class="suggestion-btn" data-question="What can you help with based on metrics?">Detail metrics</button>
                    <button class="suggestion-btn" data-question="Show me the conversion rate">Conversion rate</button>
                    <button class="suggestion-btn" data-question="What are the top 5 destinations?">Top destinations</button>
                    <button class="suggestion-btn" data-question="Average view duration?">View duration</button>
                    <button class="suggestion-btn" data-question="Searches and views last week">Weekly stats</button>
                </div>
            </div>

            <div class="sidebar-status">
                <div class="status-item">
                    <span class="status-indicator active"></span>
                    <span class="status-label">AI Engine: Online</span>
                </div>
            </div>
        </div>

        <!-- Main Chat Area -->
        <div class="chat-console">
            <div class="chat-messages-container" id="chatMessages">
                <!-- Welcome Message -->
                <div class="message assistant">
                    <div class="message-wrapper">
                        <div class="message-avatar">🤖</div>
                        <div class="message-content">
                            <div class="bubble">
                                <p><strong>Greetings, Administrator.</strong></p>
                                <p>I am the Travagir intelligence engine. I have real-time access to our travel database and user analytics. How may I assist your decision-making today?</p>
                            </div>
                            <span class="message-time">Just now</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="chat-input-container">
                <div class="input-wrapper">
                    <textarea 
                        id="questionInput" 
                        placeholder="Describe what you want to know about your data..." 
                        rows="1"
                    ></textarea>
                    <button id="sendBtn" class="send-action-btn" title="Send Question">
                        <svg viewBox="0 0 24 24" width="24" height="24">
                            <path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path>
                        </svg>
                    </button>
                </div>
                <p class="input-hint">Press <strong>Enter</strong> to send, <strong>Shift + Enter</strong> for a new line.</p>
            </div>
        </div>
    </div>
</div>

<style>
.ai-assistant-container {
    padding: 30px 0;
    animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Header & Breadcrumbs */
.ai-header-wrap {
    margin-bottom: 30px;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: 0.9rem;
    color: var(--text-muted);
}

.breadcrumb a {
    color: var(--text-muted);
    transition: color 0.2s;
}

.breadcrumb a:hover {
    color: var(--amazon-orange);
}

.breadcrumb .separator {
    color: var(--border-dark);
}

.breadcrumb .current {
    color: var(--text-primary);
    font-weight: 600;
}

.header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
}

.header-main h1 {
    margin: 0;
    font-size: 2.2rem;
    font-weight: 800;
}

.subtitle {
    margin: 4px 0 0 0;
    color: var(--text-muted);
    font-size: 1.1rem;
}

.header-actions {
    display: flex;
    gap: 12px;
}

/* Console Grid */
.ai-console-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 30px;
    height: 700px;
}

/* Sidebar */
.console-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.sidebar-section {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 20px;
    padding: 24px;
}

.sidebar-section h3 {
    margin: 0 0 16px 0;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.capability-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.capability-list li {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 10px;
}

.capability-list li::before {
    content: '◈';
    color: var(--amazon-orange);
    font-size: 0.8rem;
}

.suggestion-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.suggestion-btn {
    background: var(--amazon-dark);
    border: 1px solid var(--border-dark);
    color: var(--text-primary);
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.85rem;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
}

.suggestion-btn:hover {
    border-color: var(--amazon-orange);
    background: rgba(255, 153, 0, 0.05);
    transform: translateX(5px);
}

.sidebar-status {
    margin-top: auto;
    padding: 16px;
    background: rgba(22, 163, 74, 0.05);
    border: 1px solid rgba(22, 163, 74, 0.2);
    border-radius: 12px;
}

.status-item {
    display: flex;
    align-items: center;
    gap: 10px;
}

.status-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
}

.status-indicator.active {
    background: #16a34a;
    box-shadow: 0 0 10px rgba(22, 163, 74, 0.5);
}

.status-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #22c55e;
}

/* Chat Console */
.chat-console {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.chat-messages-container {
    flex: 1;
    overflow-y: auto;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    background: rgba(0, 0, 0, 0.2);
}

.message {
    display: flex;
    animation: messageIn 0.3s ease-out;
}

@keyframes messageIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.message.assistant { justify-content: flex-start; }
.message.user { justify-content: flex-end; }

.message-wrapper {
    display: flex;
    gap: 15px;
    max-width: 80%;
}

.message.user .message-wrapper {
    flex-direction: row-reverse;
}

.message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--amazon-dark);
    border: 1px solid var(--border-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.message.user .message-avatar {
    background: var(--amazon-orange);
    color: #0a0f1c;
    border: none;
}

.message-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.message.user .message-content {
    align-items: flex-end;
}

.bubble {
    padding: 16px 20px;
    border-radius: 20px;
    font-size: 1rem;
    line-height: 1.5;
    word-wrap: break-word;
}

.message.assistant .bubble {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    color: var(--text-primary);
    border-top-left-radius: 4px;
}

.message.user .bubble {
    background: var(--amazon-orange);
    color: #0a0f1c;
    border-top-right-radius: 4px;
    font-weight: 500;
}

.message-time {
    font-size: 0.75rem;
    color: var(--text-muted);
}

/* Typing Indicator */
.typing-indicator {
    display: flex;
    gap: 4px;
    padding: 10px 0;
}

.typing-indicator span {
    width: 8px;
    height: 8px;
    background: var(--amazon-orange);
    border-radius: 50%;
    animation: typing 1s infinite;
}

.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.2); opacity: 1; }
}

/* Input Area */
.chat-input-container {
    padding: 24px 30px;
    background: var(--amazon-navy);
    border-top: 1px solid var(--border-dark);
}

.input-wrapper {
    display: flex;
    gap: 15px;
    align-items: flex-end;
    background: var(--amazon-dark);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    padding: 8px 16px;
    transition: all 0.2s;
}

.input-wrapper:focus-within {
    border-color: var(--amazon-orange);
    box-shadow: 0 0 0 4px rgba(255, 153, 0, 0.1);
}

textarea#questionInput {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    padding: 12px 0;
    font-size: 1rem;
    resize: none;
    max-height: 150px;
    outline: none;
    font-family: inherit;
}

.send-action-btn {
    background: var(--amazon-orange);
    color: #0a0f1c;
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 4px;
}

.send-action-btn:hover {
    background: #e68a00;
    transform: scale(1.05);
}

.send-action-btn:disabled {
    background: var(--border-dark);
    color: var(--text-muted);
    cursor: not-allowed;
    transform: none;
}

.input-hint {
    margin: 12px 0 0 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
}

/* Responsive */
@media (max-width: 992px) {
    .ai-console-grid {
        grid-template-columns: 1fr;
        height: auto;
    }
    
    .console-sidebar {
        display: none; /* Hide sidebar on smaller screens or use a toggle */
    }
    
    .chat-console {
        height: 600px;
    }
}

@media (max-width: 600px) {
    .header-main {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .header-actions {
        width: 100%;
    }
    
    .header-actions .btn {
        flex: 1;
        text-align: center;
    }
}
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatMessages = document.getElementById('chatMessages');
        const questionInput = document.getElementById('questionInput');
        const sendBtn = document.getElementById('sendBtn');

        function addMessage(role, content) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${role}`;
            
            const avatar = role === 'user' ? '👤' : '🤖';
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            messageDiv.innerHTML = `
                <div class="message-wrapper">
                    <div class="message-avatar">${avatar}</div>
                    <div class="message-content">
                        <div class="bubble">${content.replace(/\n/g, '<br>')}</div>
                        <span class="message-time">${time}</span>
                    </div>
                </div>
            `;
            
            chatMessages.appendChild(messageDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            return messageDiv;
        }

        function showTyping() {
            const typingDiv = document.createElement('div');
            typingDiv.className = 'message assistant';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = `
                <div class="message-wrapper">
                    <div class="message-avatar">🤖</div>
                    <div class="message-content">
                        <div class="bubble">
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function removeTyping() {
            const typing = document.getElementById('typingIndicator');
            if (typing) typing.remove();
        }

        async function sendQuestion() {
            const question = questionInput.value.trim();
            if (!question) return;

            // Disable UI
            sendBtn.disabled = true;
            questionInput.disabled = true;

            // Add user message
            addMessage('user', question);
            questionInput.value = '';
            questionInput.style.height = 'auto';

            // Show typing indicator
            showTyping();

            try {
                const response = await fetch('{{ path('ai_ask') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ question: question })
                });

                if (!response.ok) throw new Error('Network response was not ok');

                const data = await response.json();
                removeTyping();
                addMessage('assistant', data.answer || 'I apologize, but I encountered an error processing that request.');
            } catch (error) {
                console.error('Error:', error);
                removeTyping();
                addMessage('assistant', '❌ Connection error. Please verify the server status and try again.');
            } finally {
                sendBtn.disabled = false;
                questionInput.disabled = false;
                questionInput.focus();
            }
        }

        // Auto-resize textarea
        questionInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 150) + 'px';
        });

        // Submit patterns
        questionInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendQuestion();
            }
        });

        sendBtn.addEventListener('click', sendQuestion);

        // Suggestions
        document.querySelectorAll('.suggestion-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                questionInput.value = btn.getAttribute('data-question');
                sendQuestion();
            });
        });
    });
</script>
{% endblock %}