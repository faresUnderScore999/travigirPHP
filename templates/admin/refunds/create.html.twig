{% extends 'base.html.twig' %}
{% block title %}Admin – New Refund Request{% endblock %}

{% block stylesheets %}
<style>
.rf-header { margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border-dark); }
.rf-header h1 {
    margin: 0 0 4px;
    font-size: 1.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, #ffffff 0%, #febd69 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.rf-header .subtitle { font-size: 0.85em; color: var(--text-muted); }
.rf-form-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 14px;
    padding: 32px;
    max-width: 680px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
}
.rf-form-group { margin-bottom: 20px; }
.rf-form-group label { display: block; font-size: 0.82em; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 7px; }
.rf-form-group input,
.rf-form-group select,
.rf-form-group textarea {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    color: var(--text-primary);
    padding: 10px 14px;
    font-size: 0.9rem;
    outline: none;
    transition: border-color .2s;
    box-sizing: border-box;
}
.rf-form-group input:focus,
.rf-form-group select:focus,
.rf-form-group textarea:focus { border-color: #ff9900; }
.rf-form-group select option { background: #1a1a2e; }
.rf-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.rf-btn-row { display: flex; gap: 12px; margin-top: 8px; }
.btn-rf-save {
    background: linear-gradient(135deg, #ff9900, #febd69);
    color: #131a22;
    border: none;
    padding: 11px 28px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity .2s;
}
.btn-rf-save:hover { opacity: .85; }
.btn-rf-cancel {
    background: rgba(255,255,255,0.06);
    color: var(--text-muted);
    border: 1px solid var(--border-dark);
    padding: 11px 22px;
    border-radius: 8px;
    font-size: 0.9rem;
    text-decoration: none;
    display: inline-block;
    transition: background .2s;
}
.btn-rf-cancel:hover { background: rgba(255,255,255,0.1); }
.alert-error { background: rgba(220,38,38,0.12); border: 1px solid rgba(220,38,38,0.3); color: #fca5a5; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 0.88rem; }
</style>
{% endblock %}

{% block body %}
<div class="rf-header">
    <h1>New Refund Request</h1>
    <p class="subtitle">Manually create a refund request on behalf of a customer</p>
</div>

{% if errors is defined and errors|length %}
    {% for e in errors %}
        <div class="alert-error">{{ e }}</div>
    {% endfor %}
{% endif %}

<div class="rf-form-card">
    <form method="post">
        <div class="rf-form-group">
            <label for="requester_id">Customer *</label>
            <select id="requester_id" name="requester_id" required>
                <option value="">— Select customer —</option>
                {% for u in users %}
                    <option value="{{ u.id }}" {% if app.request.request.get('requester_id') == u.id|string %}selected{% endif %}>
                        {{ u.username }} ({{ u.email }})
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="rf-form-row">
            <div class="rf-form-group">
                <label for="amount">Amount (TND) *</label>
                <input type="number" id="amount" name="amount" min="0.01" step="0.01"
                       value="{{ app.request.request.get('amount', '') }}" required placeholder="0.00">
            </div>
            <div class="rf-form-group">
                <label for="status">Initial Status</label>
                <select id="status" name="status">
                    <option value="PENDING" {% if app.request.request.get('status', 'PENDING') == 'PENDING' %}selected{% endif %}>PENDING</option>
                    <option value="APPROVED" {% if app.request.request.get('status') == 'APPROVED' %}selected{% endif %}>APPROVED</option>
                    <option value="REJECTED" {% if app.request.request.get('status') == 'REJECTED' %}selected{% endif %}>REJECTED</option>
                </select>
            </div>
        </div>

        <div class="rf-form-row">
            <div class="rf-form-group">
                <label for="reservation_id">Reservation ID (optional)</label>
                <input type="number" id="reservation_id" name="reservation_id" min="1" step="1"
                       value="{{ app.request.request.get('reservation_id', '') }}" placeholder="e.g. 21">
            </div>
            <div class="rf-form-group">
                <label for="reclamation_id">Reclamation ID (optional)</label>
                <input type="number" id="reclamation_id" name="reclamation_id" min="1" step="1"
                       value="{{ app.request.request.get('reclamation_id', '') }}" placeholder="e.g. 5">
            </div>
        </div>

        <div class="rf-form-group">
            <label for="reason">Reason *</label>
            <textarea id="reason" name="reason" rows="4" required
                      placeholder="Describe the reason for the refund…">{{ app.request.request.get('reason', '') }}</textarea>
        </div>

        <div class="rf-btn-row">
            <button type="submit" class="btn-rf-save">Create Refund</button>
            <a href="{{ path('admin_refunds') }}" class="btn-rf-cancel">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}
